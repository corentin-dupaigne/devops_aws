# Copy to terraform.tfvars then set your admin IP.
# (terraform.tfvars is gitignored; this .example is committed.)

project  = "pomodoro"
region   = "us-east-1"
vpc_cidr = "10.0.0.0/16"
az_count = 2

# YOUR public IP as /32 (get it with: curl -s https://checkip.amazonaws.com)
admin_cidr = "203.0.113.4/32"

# RDS Multi-AZ: false for the lab, true for real resilience.
db_multi_az = false
